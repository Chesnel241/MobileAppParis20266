{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:demo",
  "outputDirectory": "dist",
  "framework": null,

  "build": {
    "env": {
      "VITE_API_URL": "same-origin"
    }
  },

  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },

  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/((?!api/|assets/|admin|privacy.html|sw.js|manifest.webmanifest|.*\\.[a-zA-Z0-9]+$).*)", "destination": "/index.html" }
  ],

  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "no-referrer" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), payment=(), usb=()" }
      ]
    }
  ]
}
