# Copiez ce fichier en .env sur le VPS puis renseignez vos valeurs :
#   cp deploy.env.example .env

# Domaine (ou sous-domaine) pointant vers le VPS Hetzner via un enregistrement DNS A.
# Exemple : api.convention-paris2026.org
DOMAIN=api.votre-domaine.fr

# Email pour les certificats Let's Encrypt (notifications d'expiration).
ACME_EMAIL=vous@votre-domaine.fr

# Code administrateur commun (organisateurs & pasteurs). À CHANGER impérativement.
ADMIN_CODE=CHANGEZ_MOI

# Durée de validité d'une session admin (heures).
ADMIN_SESSION_HOURS=24
