# URL de l'API.
#   - « same-origin » : l'app et l'API sont déployées ensemble sur Vercel (recommandé).
#   - une URL absolue https://… si l'API est sur un autre domaine.
#   - vide : mode local, sans synchronisation.
VITE_API_URL=same-origin

# Chemin de déploiement si l'app est servie sous un sous-chemin (ex. /app/).
# VITE_BASE_PATH=/app/
