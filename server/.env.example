# Port d'écoute de l'API
PORT=8080

# Secret administrateur commun (16 caractères minimum, avec majuscule, minuscule,
# chiffre et symbole). Cette valeur d'exemple est volontairement refusée au démarrage.
ADMIN_CODE=CHANGE_ME_WITH_A_RANDOM_SECRET_32_CHARS

# Chemin de la base SQLite (persistée sur un volume en production)
DB_PATH=./data/paris2026.db

# Dossier des fichiers téléversés (photos, audios) — sur volume persistant en prod
UPLOADS_DIR=./data/uploads

# Durée de validité d'une session admin, en heures
ADMIN_SESSION_HOURS=24

# Origines CORS autorisées (obligatoires en production, séparées par des virgules).
CORS_ORIGINS=https://api.votre-domaine.fr,capacitor://localhost,http://localhost

# ---- Authentification des administrateurs par comptes Supabase (recommandé) ----
# Réutilise les comptes déjà créés sur dlwm-convention2026.fr.
# Laisser SUPABASE_URL vide pour n'utiliser que le code partagé.
SUPABASE_URL=https://VOTRE-PROJET.supabase.co
SUPABASE_ANON_KEY=votre_cle_anon_publique

# Qui a le droit d'administrer l'app mobile ? Au moins l'un des deux est
# OBLIGATOIRE dès que SUPABASE_URL est défini (sinon tout compte Supabase
# deviendrait administrateur — le serveur refuse de démarrer).
SUPABASE_ADMIN_EMAILS=organisateur1@exemple.fr,organisateur2@exemple.fr
SUPABASE_ADMIN_ROLE=

# Passer à false pour désactiver le code partagé une fois Supabase validé.
ALLOW_ADMIN_CODE=true

# ---- Notifications push web (VAPID) ----
# Générez la paire une seule fois :
#   cd server && node -e "console.log(require('web-push').generateVAPIDKeys())"
# La clé publique est exposée à l'app (normal) ; la privée reste secrète.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:sfdrm.lwm@gmail.com
