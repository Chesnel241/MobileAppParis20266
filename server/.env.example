# Port d'écoute de l'API
PORT=8080

# Code administrateur commun (organisateurs & pasteurs) — À CHANGER en production
ADMIN_CODE=LWMFD2026

# Chemin de la base SQLite (persistée sur un volume en production)
DB_PATH=./data/paris2026.db

# Dossier des fichiers téléversés (photos, audios) — sur volume persistant en prod
UPLOADS_DIR=./data/uploads

# Durée de validité d'une session admin, en heures
ADMIN_SESSION_HOURS=24

# Origines CORS autorisées (séparées par des virgules) ; vide = toutes
CORS_ORIGINS=
